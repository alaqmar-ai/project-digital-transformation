# EPMS — environment variables
# ───────────────────────────────────────────────────────────────────────────
# Local dev runs on localStorage out of the box. To connect a real database:
#
#   1. Install Neon (or any Postgres) via Vercel → Storage → Browse Storage
#   2. `vercel env pull .env.local`  — pulls DATABASE_URL and friends
#   3. Add the line below to .env.local so the client knows to call server
#      actions instead of localStorage:
#
#         NEXT_PUBLIC_USE_NEON=true
#
#   4. `npm run db:migrate`           — applies db/migrations/*.sql to Neon
# ───────────────────────────────────────────────────────────────────────────

# Neon / Vercel Postgres connection string (server-only)
DATABASE_URL=

# Flip to "true" once DATABASE_URL is populated to route reads/writes
# through Server Actions. Otherwise the app stays on the localStorage demo.
NEXT_PUBLIC_USE_NEON=
